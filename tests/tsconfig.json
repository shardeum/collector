{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "./dist",
    "rootDir": "../",
    "types": ["node", "jest"],
    "lib": ["es2020"]
  },
  "include": [
    "**/*",
    "../src/**/*"
  ],
  "exclude": [
    "../node_modules",
    "../dist"
  ]
}